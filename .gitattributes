# Normalize text files to LF in the repo (silences CRLF conversion warnings)
* text=auto eol=lf

# Explicit text types
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.svg   text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Binary assets — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.woff2 binary
*.ico   binary
